# فایل اینونتوری سرورهای استریم؛ توسط scripts/add_stream_node.sh خونده و آپدیت می‌شه.
# این فایل شامل IP/پورت واقعی زیرساخته، پس commit نمی‌شه (تو .gitignore هست)؛
# یه کپی از این فایل نمونه به اسم scripts/nodes.conf بساز و مقدار سرور اول (local)
# رو با پهنای‌باند واقعیش پر کن.
#
# ستون‌ها: name  tunnel_ip  ssh_host  ssh_port  mbps
# سرور اول (local) همیشه با ssh_host=- مشخص می‌شه چون همین ماشینه
local     10.10.0.1     -                  -       200
