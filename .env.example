API_ID=
API_HASH=
BOT_TOKEN=

# پورت و آدرسی که وب‌سرور استریم روش بالا میاد
PORT=8085
BIND_ADDRESS=0.0.0.0

# آدرس عمومی که تو لینک‌های خروجی استفاده میشه (دامنه یا IP سرورت رو اینجا بذار)
BASE_URL=http://127.0.0.1:8085

# اختیاری: آیدی عددی یک کانال خصوصی که ربات توش ادمینه، فقط برای گزارش/لاگ متنی
# (نام فایل، حجم، فرستنده) هر فایل جدید؛ خودِ فایل به این کانال کپی نمیشه
LOG_CHANNEL=

# آیدی عددی ادمین ربات؛ فقط این کاربر می‌تونه از دستور /traffic استفاده کنه
ADMIN_ID=

# آدرس ردیس؛ برای نگهداری لینک‌های فعال، صف، محدودیت‌های نرخ و pacing پهنای‌باند
# (پایدار در برابر ری‌استارت). اگه چند سرور استریم داری (app/stream_node.py روی
# سرورهای اضافی)، همه باید به همین یک Redis مشترک وصل بشن تا سقف پهنای‌باند/لینک
# فعال سراسری بمونه
REDIS_URL=redis://127.0.0.1:6379/0

# اختیاری: یوزرنیم کانالی که عضویت توش برای استفاده از بات اجباریه (بدون @)
# بات باید عضو/ادمین این کانال باشه تا بتونه عضویت کاربرها رو چک کنه
FORCE_JOIN_CHANNEL=
