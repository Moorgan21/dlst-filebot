API_ID=
API_HASH=
BOT_TOKEN=

# پورت و آدرسی که وب‌سرور استریم روش بالا میاد
PORT=8085
BIND_ADDRESS=0.0.0.0

# آدرس عمومی که تو لینک‌های خروجی استفاده میشه (دامنه یا IP سرورت رو اینجا بذار)
BASE_URL=http://127.0.0.1:8085

# اختیاری: آیدی عددی یک کانال خصوصی که ربات توش ادمینه، برای نگهداری پایدار فایل‌ها
# اگه خالی بمونه، فایل همون‌جایی که کاربر فرستاده (چت خصوصی با ربات) نگه داشته میشه
LOG_CHANNEL=

# آیدی عددی ادمین ربات؛ فقط این کاربر می‌تونه از دستور /traffic استفاده کنه
ADMIN_ID=
